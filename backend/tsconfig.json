      "@pssms/finance/*": ["libs/finance/*"],
      "@pssms/procurement": ["libs/procurement/index.ts"],
      "@pssms/procurement/*": ["libs/procurement/*"],
      "@pssms/inventory": ["libs/inventory/index.ts"],
      "@pssms/inventory/*": ["libs/inventory/*"],
      "@pssms/assets": ["libs/assets/index.ts"],
      "@pssms/assets/*": ["libs/assets/*"],
      "@pssms/notifications": ["libs/notifications/index.ts"],
      "@pssms/notifications/*": ["libs/notifications/*"],
      "@pssms/reporting": ["libs/reporting/index.ts"],
      "@pssms/reporting/*": ["libs/reporting/*"]
