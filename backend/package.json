{
  "name": "pssms-backend",
  "version": "0.1.0",
  "private": true,
  "description": "HIGHLINK PSSMS — NestJS modular monolith backend",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:core": "nest start core-api --watch",
    "start:integration": "nest start integration-gateway --watch",
    "start:worker": "nest start background-worker --watch",
    "start:realtime": "nest start realtime-gateway --watch",
    "start:reporting": "nest start reporting-service --watch",
    "start:gateway": "nest start api-gateway --watch",
    "build:all": "nest build core-api && nest build integration-gateway && nest build background-worker && nest build realtime-gateway && nest build reporting-service && nest build api-gateway",
    "start:prod": "node dist/apps/core-api/main.js",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seeds/seed.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seeds/seed.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.3.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^6.5.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "webpack": "^5.108.4"
  }
}
