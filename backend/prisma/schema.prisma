  category           String
  receiptUrl         String?                @map("receipt_url")
  status             PettyCashVoucherStatus @default(PENDING)
  approvalInstanceId String?                @map("approval_instance_id")
  approvedBy         String?                @map("approved_by")
  reimbursedAt       DateTime?              @map("reimbursed_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  createdBy          String                 @map("created_by")

  fund PettyCashFund @relation(fields: [fundId], references: [id])

  @@unique([organizationId, voucherNumber])
  @@map("petty_cash_vouchers")
  @@schema("finance")
}

model PaymentVoucher {
  id                 String               @id @default(uuid())
  organizationId     String               @map("organization_id")
  voucherNumber      String               @map("voucher_number")
  payeeName          String               @map("payee_name")
  supplierId         String?              @map("supplier_id")
  purchaseOrderId    String?              @map("purchase_order_id")
  amount             Decimal              @db.Decimal(14, 2)
  currency           String               @default("TZS")
  purpose            String
  status             PaymentVoucherStatus @default(DRAFT)
  approvalInstanceId String?              @map("approval_instance_id")
  approvedBy         String?              @map("approved_by")
  paidAt             DateTime?            @map("paid_at")
  paymentReference   String?              @map("payment_reference")
  createdAt          DateTime             @default(now()) @map("created_at")
  createdBy          String               @map("created_by")

  @@unique([organizationId, voucherNumber])
  @@index([supplierId, status])
  @@map("payment_vouchers")
  @@schema("finance")
}

// ───────────────────────── PROCUREMENT ─────────────────────────

enum SupplierStatus {
  PENDING
  APPROVED
  SUSPENDED

  @@schema("procurement")
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED

  @@schema("procurement")
}

model Supplier {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  code           String
  name           String
  email          String?
  phone          String?
  tin            String?
  address        String?
  status         SupplierStatus @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at")
  createdBy      String?        @map("created_by")

  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, code])
  @@map("suppliers")
  @@schema("procurement")
}

model PurchaseOrder {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  supplierId         String              @map("supplier_id")
  poNumber           String              @map("po_number")
  status             PurchaseOrderStatus @default(DRAFT)
  totalAmount        Decimal             @map("total_amount") @db.Decimal(14, 2)
  currency           String              @default("TZS")
  expectedDelivery   DateTime?           @map("expected_delivery") @db.Date
  approvalInstanceId String?             @map("approval_instance_id")
  approvedBy         String?             @map("approved_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  createdBy          String              @map("created_by")

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]
  receipts GoodsReceipt[]

  @@unique([organizationId, poNumber])
  @@map("purchase_orders")
  @@schema("procurement")
}

model PurchaseOrderLine {
  id              String  @id @default(uuid())
  purchaseOrderId String  @map("purchase_order_id")
  stockItemId     String? @map("stock_item_id")
  description     String
  quantity        Decimal @db.Decimal(10, 2)
  unitPrice       Decimal @map("unit_price") @db.Decimal(14, 2)
  amount          Decimal @db.Decimal(14, 2)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_lines")
  @@schema("procurement")
}

model GoodsReceipt {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  purchaseOrderId String   @map("purchase_order_id")
  grnNumber       String   @map("grn_number")
  receivedAt      DateTime @default(now()) @map("received_at")
  receivedBy      String   @map("received_by")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  lines         GoodsReceiptLine[]

  @@unique([organizationId, grnNumber])
  @@map("goods_receipts")
  @@schema("procurement")
}

model GoodsReceiptLine {
  id                  String  @id @default(uuid())
  goodsReceiptId      String  @map("goods_receipt_id")
  purchaseOrderLineId String  @map("purchase_order_line_id")
  quantityReceived    Decimal @map("quantity_received") @db.Decimal(10, 2)

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@map("goods_receipt_lines")
  @@schema("procurement")
}

// ───────────────────────── INVENTORY ─────────────────────────

enum StockMovementType {
  IN
  OUT
  ADJUST

  @@schema("inventory")
}

model StockItem {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  sku            String
  name           String
  category       String?
  unit           String   @default("EA")
  reorderLevel   Int?     @map("reorder_level")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")

  movements StockMovement[]

  @@unique([organizationId, sku])
  @@map("stock_items")
  @@schema("inventory")
}

model StockMovement {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  stockItemId    String            @map("stock_item_id")
  siteId         String?           @map("site_id")
  movementType   StockMovementType @map("movement_type")
  quantity       Decimal           @db.Decimal(10, 2)
  referenceType  String?           @map("reference_type")
  referenceId    String?           @map("reference_id")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  createdBy      String?           @map("created_by")

  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@index([stockItemId, createdAt])
  @@map("stock_movements")
  @@schema("inventory")
}

// ───────────────────────── ASSETS ─────────────────────────

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  DISPOSED

  @@schema("assets")
}

model Asset {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  assetTag       String      @map("asset_tag")
  name           String
  category       String?
  purchaseDate   DateTime?   @map("purchase_date") @db.Date
  purchaseCost   Decimal?    @map("purchase_cost") @db.Decimal(14, 2)
  serialNumber   String?     @map("serial_number")
  status         AssetStatus @default(AVAILABLE)
  createdAt      DateTime    @default(now()) @map("created_at")
  createdBy      String?     @map("created_by")

  assignments AssetAssignment[]

  @@unique([organizationId, assetTag])
  @@map("assets")
  @@schema("assets")
}

model AssetAssignment {
  id                    String    @id @default(uuid())
  organizationId        String    @map("organization_id")
  assetId               String    @map("asset_id")
  assignedToEmployeeId  String?   @map("assigned_to_employee_id")
  assignedToGuardId      String?   @map("assigned_to_guard_id")
  assignedAt            DateTime  @default(now()) @map("assigned_at")
  returnedAt            DateTime? @map("returned_at")
  notes                 String?
  createdBy             String?   @map("created_by")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId, assignedAt])
  @@map("asset_assignments")
  @@schema("assets")
}

// ───────────────────────── INTEGRATIONS ─────────────────────────

enum WebhookInboxStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DLQ

  @@schema("integrations")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED

  @@schema("integrations")
}

enum IntegrationProviderCategory {
  SMS
  WHATSAPP
  EMAIL
  PAYMENT
  ANPR
  GATE

  @@schema("integrations")
}

model ProviderRegistry {
  id           String                    @id @default(uuid())
  code         String                    @unique
  category     IntegrationProviderCategory
  adapterClass String                    @map("adapter_class")
  isEnabled    Boolean                   @default(true) @map("is_enabled")
  createdAt    DateTime                  @default(now()) @map("created_at")

  @@map("provider_registry")
  @@schema("integrations")
}

model WebhookInbox {
  id              String             @id @default(uuid())
  organizationId  String?            @map("organization_id")
  provider        String
  eventType       String             @map("event_type")
  idempotencyKey  String             @unique @map("idempotency_key")
  rawHeaders      Json?              @map("raw_headers")
  rawBody         Json               @map("raw_body")
  signatureValid  Boolean            @default(false) @map("signature_valid")
  status          WebhookInboxStatus @default(RECEIVED)
  retryCount      Int                @default(0) @map("retry_count")
  errorMessage    String?            @map("error_message")
  processedAt     DateTime?          @map("processed_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("webhook_inbox")
  @@schema("integrations")
}

model IntegrationOutbox {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  eventType      String       @map("event_type")
  aggregateType  String       @map("aggregate_type")
  aggregateId    String       @map("aggregate_id")
  payload        Json
  status         OutboxStatus @default(PENDING)
  idempotencyKey String       @unique @map("idempotency_key")
  retryCount     Int          @default(0) @map("retry_count")
  nextRetryAt    DateTime     @default(now()) @map("next_retry_at")
  publishedAt    DateTime?    @map("published_at")
  errorMessage   String?      @map("error_message")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([status, nextRetryAt])
  @@map("integration_outbox")
  @@schema("integrations")
}

model IntegrationRequestLog {
  id            String   @id @default(uuid())
  organizationId String? @map("organization_id")
  provider      String
  direction     String
  correlationId String?  @map("correlation_id")
  statusCode    Int?     @map("status_code")
  durationMs    Int?     @map("duration_ms")
  summary       String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([provider, createdAt])
  @@map("integration_request_logs")
  @@schema("integrations")
}

// ───────────────────────── NOTIFICATIONS ─────────────────────────

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH

  @@schema("notifications")
}

enum NotificationStatus {
  PENDING
  DISPATCHING
  SENT
  FAILED

  @@schema("notifications")
}

model NotificationTemplate {
  id              String              @id @default(uuid())
  code            String              @unique
  channel         NotificationChannel
  subjectTemplate String?             @map("subject_template")
  bodyTemplate    String              @map("body_template")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@map("notification_templates")
  @@schema("notifications")
}

model Notification {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  templateCode   String              @map("template_code")
  channel        NotificationChannel
  recipient      String
  subject        String?
  body           String
  payload        Json?
  status         NotificationStatus  @default(PENDING)
  resourceType   String?             @map("resource_type")
  resourceId     String?             @map("resource_id")
  idempotencyKey String              @unique @map("idempotency_key")
  correlationId  String?             @map("correlation_id")
  sentAt         DateTime?           @map("sent_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  attempts NotificationDeliveryAttempt[]

  @@index([organizationId, status, createdAt])
  @@map("notifications")
  @@schema("notifications")
}

model NotificationDeliveryAttempt {
  id                String   @id @default(uuid())
  notificationId    String   @map("notification_id")
  attemptNumber     Int      @map("attempt_number")
  provider          String
  providerMessageId String?  @map("provider_message_id")
  status            String
  errorMessage      String?  @map("error_message")
  durationMs        Int?     @map("duration_ms")
  createdAt         DateTime @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_delivery_attempts")
  @@schema("notifications")
}

// ───────────────────────── REPORTING ─────────────────────────

enum KpiPeriodGranularity {
  DAY
  WEEK
  MONTH

  @@schema("reporting")
}

enum KpiSnapshotStatus {
  COMPUTING
  READY
  FAILED
  STALE

  @@schema("reporting")
}

model KpiDefinition {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  code           String   @unique
  name           String
  description    String?
  category       String
  unit           String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("kpi_definitions")
  @@schema("reporting")
}

model KpiSnapshot {
  id             String               @id @default(uuid())
  organizationId String               @map("organization_id")
  kpiCode        String               @map("kpi_code")
  granularity    KpiPeriodGranularity @default(DAY)
  periodStart    DateTime             @map("period_start") @db.Date
  periodEnd      DateTime             @map("period_end") @db.Date
  scopeKey       String               @default("all") @map("scope_key")
  branchId       String?              @map("branch_id")
  siteId         String?              @map("site_id")
  customerId     String?              @map("customer_id")
  valueNumeric   Decimal              @map("value_numeric") @db.Decimal(18, 4)
  valueJson      Json?                @map("value_json")
  status         KpiSnapshotStatus    @default(READY)
  sourceHash     String?              @map("source_hash")
  computedAt     DateTime             @default(now()) @map("computed_at")
  computedBy     String?              @map("computed_by")

  @@unique([organizationId, kpiCode, granularity, periodStart, periodEnd, scopeKey])
  @@index([organizationId, kpiCode, periodStart])
  @@map("kpi_snapshots")
  @@schema("reporting")
}

model AnalyticsInsight {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  insightType    String    @map("insight_type")
  domain         String
  title          String
  summary        String
  score          Decimal?  @db.Decimal(8, 4)
  payload        Json
  periodStart    DateTime? @map("period_start")
  periodEnd      DateTime? @map("period_end")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String?   @map("created_by")

  @@index([organizationId, insightType, createdAt])
  @@map("analytics_insights")
  @@schema("reporting")
}

model DashboardCache {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dashboardCode  String   @map("dashboard_code")
  filtersHash    String   @map("filters_hash")
  payload        Json
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([organizationId, dashboardCode, filtersHash])
  @@map("dashboard_caches")
  @@schema("reporting")
}

