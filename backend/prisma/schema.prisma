generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["iam", "enterprise", "customers", "contracts", "approvals", "audit", "workforce", "operations", "attendance", "incidents", "occurrence", "access", "visitors", "parking", "recruitment", "payroll", "employee_loans", "finance", "procurement", "inventory", "assets", "integrations", "notifications", "reporting", "public"]
}

// ───────────────────────── IAM ─────────────────────────

model User {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  customerId       String?   @map("customer_id")
  supplierId       String?   @map("supplier_id")
  email            String    @unique
  passwordHash     String    @map("password_hash")
  fullName         String    @map("full_name")
  phone            String?
  keycloakSub      String?   @unique @map("keycloak_sub")
  isActive         Boolean   @default(true) @map("is_active")
  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        String?   @map("created_by")

  organization     Organization @relation(fields: [organizationId], references: [id])
  roles            UserRole[]
  branchAccess     UserBranchAccess[]
  siteAccess       UserSiteAccess[]
  loginHistory     LoginHistory[]

  @@index([organizationId, customerId])
  @@index([organizationId, supplierId])
  @@map("users")
  @@schema("iam")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")

  permissions    RolePermission[]
  users          UserRole[]

  @@unique([organizationId, code])
  @@map("roles")
  @@schema("iam")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  name        String
  module      String
  description String?

  roles RolePermission[]

  @@map("permissions")
  @@schema("iam")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("iam")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("iam")
}

model UserBranchAccess {
  userId   String @map("user_id")
  branchId String @map("branch_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branch_access")
  @@schema("iam")
}

model UserSiteAccess {
  userId String @map("user_id")
  siteId String @map("site_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_site_access")
  @@schema("iam")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_history")
  @@schema("iam")
}

// ───────────────────────── ENTERPRISE ─────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  tin       String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  branches     Branch[]
  departments  Department[]
  sites        Site[]
  customers    Customer[]
  contracts    Contract[]

  @@map("organizations")
  @@schema("enterprise")
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  region         String?
  phone          String?
  address        String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")

  organization Organization @relation(fields: [organizationId], references: [id])
  sites        Site[]
  departments  Department[]

  @@unique([organizationId, code])
  @@map("branches")
  @@schema("enterprise")
}

model Department {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  branchId       String?  @map("branch_id")
  code           String
  name           String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])

  @@unique([organizationId, code])
  @@map("departments")
  @@schema("enterprise")
}

model Site {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  branchId       String   @map("branch_id")
  customerId     String?  @map("customer_id")
  code           String
  name           String
  address        String?
  latitude       Float?
  longitude      Float?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  gates        Gate[]

  @@unique([organizationId, code])
  @@map("sites")
  @@schema("enterprise")
}

enum GateType {
  PEDESTRIAN
  VEHICLE
  MIXED

  @@schema("enterprise")
}

model Gate {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  siteId         String   @map("site_id")
  code           String
  name           String
  gateType       GateType @default(MIXED) @map("gate_type")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")

  site Site @relation(fields: [siteId], references: [id])

  @@unique([organizationId, siteId, code])
  @@map("gates")
  @@schema("enterprise")
}

// ───────────────────────── CUSTOMERS ─────────────────────────

model Customer {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  tin            String?
  email          String?
  phone          String?
  address        String?
  contactPerson  String?  @map("contact_person")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")
  version        Int      @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  contracts    Contract[]

  @@unique([organizationId, code])
  @@map("customers")
  @@schema("customers")
}

// ───────────────────────── CONTRACTS ─────────────────────────

enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EXPIRING
  TERMINATED
  CANCELLED

  @@schema("contracts")
}

model Contract {
  id               String         @id @default(uuid())
  organizationId   String         @map("organization_id")
  customerId       String         @map("customer_id")
  contractNumber   String         @map("contract_number")
  title            String
  serviceType      String         @map("service_type")
  status           ContractStatus @default(DRAFT)
  startDate        DateTime       @map("start_date")
  endDate          DateTime       @map("end_date")
  monthlyFee       Decimal        @map("monthly_fee") @db.Decimal(18, 2)
  currency         String         @default("TZS")
  guardCount       Int?           @map("guard_count")
  slaTerms         String?        @map("sla_terms")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  createdBy        String?        @map("created_by")
  version          Int            @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@unique([organizationId, contractNumber])
  @@map("contracts")
  @@schema("contracts")
}

// ───────────────────────── APPROVALS ─────────────────────────

model WorkflowDefinition {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  versions WorkflowVersion[]

  @@unique([organizationId, code])
  @@map("workflow_definitions")
  @@schema("approvals")
}

model WorkflowVersion {
  id           String   @id @default(uuid())
  definitionId String   @map("definition_id")
  version      Int
  isCurrent    Boolean  @default(true) @map("is_current")
  createdAt    DateTime @default(now()) @map("created_at")

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]
  instances  ApprovalInstance[]

  @@unique([definitionId, version])
  @@map("workflow_versions")
  @@schema("approvals")
}

model WorkflowStep {
  id              String  @id @default(uuid())
  versionId       String  @map("version_id")
  stepOrder       Int     @map("step_order")
  name            String
  requiredRole    String  @map("required_role")
  minApprovers    Int     @default(1) @map("min_approvers")
  amountThreshold Decimal? @map("amount_threshold") @db.Decimal(18, 2)

  version WorkflowVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
  @@schema("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@schema("approvals")
}

model ApprovalInstance {
  id              String         @id @default(uuid())
  versionId       String         @map("version_id")
  organizationId  String         @map("organization_id")
  resourceType    String         @map("resource_type")
  resourceId      String         @map("resource_id")
  status          ApprovalStatus @default(PENDING)
  currentStepOrder Int           @default(1) @map("current_step_order")
  amount          Decimal?       @db.Decimal(18, 2)
  createdBy       String         @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  version WorkflowVersion @relation(fields: [versionId], references: [id])
  actions ApprovalAction[]

  @@map("approval_instances")
  @@schema("approvals")
}

model ApprovalAction {
  id         String   @id @default(uuid())
  instanceId String   @map("instance_id")
  stepOrder  Int      @map("step_order")
  actorId    String   @map("actor_id")
  decision   String
  remarks    String?
  createdAt  DateTime @default(now()) @map("created_at")

  instance ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("approval_actions")
  @@schema("approvals")
}

// ───────────────────────── AUDIT ─────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorId        String?  @map("actor_id")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  before         Json?
  after          Json?
  ipAddress      String?  @map("ip_address")
  requestId      String?  @map("request_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
  @@schema("audit")
}

// ───────────────────────── WORKFORCE ─────────────────────────

enum GuardStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TRANSFERRED
  TERMINATED
  AVAILABLE

  @@schema("workforce")
}

model GuardProfile {
  id                 String      @id @default(uuid())
  organizationId     String      @map("organization_id")
  userId             String      @map("user_id")
  employeeNumber     String      @map("employee_number")
  status             GuardStatus @default(ACTIVE)
  deploymentEligible Boolean     @default(false) @map("deployment_eligible")
  photoUrl           String?     @map("photo_url")
  phone              String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  assignments ShiftAssignment[]
  attendances GuardAttendance[]
  deployments GuardDeployment[]
  employee    Employee?

  @@unique([organizationId, employeeNumber])
  @@unique([organizationId, userId])
  @@map("guard_profiles")
  @@schema("workforce")
}

// ───────────────────────── OPERATIONS ─────────────────────────

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("operations")
}

model Shift {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  siteId         String      @map("site_id")
  name           String
  startAt        DateTime    @map("start_at")
  endAt          DateTime    @map("end_at")
  status         ShiftStatus @default(SCHEDULED)
  instructions   String?
  createdAt      DateTime    @default(now()) @map("created_at")
  createdBy      String?     @map("created_by")

  assignments ShiftAssignment[]
  attendances GuardAttendance[]

  @@map("shifts")
  @@schema("operations")
}

enum AssignmentStatus {
  ASSIGNED
  CONFIRMED
  REPLACED
  NO_SHOW

  @@schema("operations")
}

model ShiftAssignment {
  id           String           @id @default(uuid())
  shiftId      String           @map("shift_id")
  guardId      String           @map("guard_id")
  supervisorId String?          @map("supervisor_id")
  status       AssignmentStatus @default(ASSIGNED)
  assignedAt   DateTime         @default(now()) @map("assigned_at")

  shift Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  guard GuardProfile @relation(fields: [guardId], references: [id])

  @@unique([shiftId, guardId])
  @@map("shift_assignments")
  @@schema("operations")
}

enum DeploymentStatus {
  PENDING
  ACTIVE
  ENDED

  @@schema("operations")
}

model GuardDeployment {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  guardId        String           @map("guard_id")
  siteId         String           @map("site_id")
  contractId     String?          @map("contract_id")
  startDate      DateTime         @map("start_date")
  endDate        DateTime?        @map("end_date")
  status         DeploymentStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at")
  createdBy      String?          @map("created_by")

  guard GuardProfile @relation(fields: [guardId], references: [id])

  @@map("guard_deployments")
  @@schema("operations")
}

model Checkpoint {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  siteId         String   @map("site_id")
  code           String
  name           String
  zone           String?
  qrCode         String?  @map("qr_code")
  nfcTagId       String?  @map("nfc_tag_id")
  latitude       Float?
  longitude      Float?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  patrolScans PatrolScan[]

  @@unique([organizationId, siteId, code])
  @@map("checkpoints")
  @@schema("operations")
}

model PatrolRoute {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  siteId         String   @map("site_id")
  name           String
  checkpointIds  String[] @map("checkpoint_ids")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("patrol_routes")
  @@schema("operations")
}

// ───────────────────────── ATTENDANCE (GUARD ONLY) ─────────────────────────

enum AttendanceMethod {
  MOBILE_GPS
  FINGERPRINT
  FACE
  QR
  NFC
  SUPERVISOR

  @@schema("attendance")
}

enum SyncStatus {
  SYNCED
  PENDING
  CONFLICT

  @@schema("attendance")
}

model GuardAttendance {
  id                 String           @id @default(uuid())
  organizationId     String           @map("organization_id")
  guardId            String           @map("guard_id")
  siteId             String           @map("site_id")
  shiftId            String?          @map("shift_id")
  clockInAt          DateTime         @map("clock_in_at")
  clockOutAt         DateTime?        @map("clock_out_at")
  clockInMethod      AttendanceMethod @map("clock_in_method")
  clockOutMethod     AttendanceMethod? @map("clock_out_method")
  clockInLatitude    Float?           @map("clock_in_latitude")
  clockInLongitude   Float?           @map("clock_in_longitude")
  clockOutLatitude   Float?           @map("clock_out_latitude")
  clockOutLongitude  Float?           @map("clock_out_longitude")
  deviceClockInAt    DateTime?        @map("device_clock_in_at")
  deviceClockOutAt   DateTime?        @map("device_clock_out_at")
  serverReceivedAt   DateTime         @default(now()) @map("server_received_at")
  clientEventId      String?          @unique @map("client_event_id")
  clockOutClientEventId String?       @unique @map("clock_out_client_event_id")
  syncStatus         SyncStatus       @default(SYNCED) @map("sync_status")
  supervisorApproved Boolean          @default(false) @map("supervisor_approved")
  remarks            String?
  createdAt          DateTime         @default(now()) @map("created_at")

  guard GuardProfile @relation(fields: [guardId], references: [id])
  shift Shift?       @relation(fields: [shiftId], references: [id])

  @@index([guardId, clockInAt])
  @@index([siteId, clockInAt])
  @@map("guard_attendances")
  @@schema("attendance")
}

enum AlertnessStatus {
  SCHEDULED
  CONFIRMED
  MISSED
  LATE

  @@schema("attendance")
}

model AlertnessCheck {
  id               String           @id @default(uuid())
  organizationId   String           @map("organization_id")
  guardId          String           @map("guard_id")
  siteId           String           @map("site_id")
  shiftId          String?          @map("shift_id")
  scheduledAt      DateTime         @map("scheduled_at")
  confirmedAt      DateTime?        @map("confirmed_at")
  status           AlertnessStatus  @default(SCHEDULED)
  method           AttendanceMethod?
  latitude         Float?
  longitude        Float?
  deviceTime       DateTime?        @map("device_time")
  serverReceivedAt DateTime?        @map("server_received_at")
  clientEventId    String?          @unique @map("client_event_id")
  referenceNumber  String           @unique @map("reference_number")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@index([guardId, scheduledAt])
  @@map("alertness_checks")
  @@schema("attendance")
}

model PatrolScan {
  id               String           @id @default(uuid())
  organizationId   String           @map("organization_id")
  guardId          String           @map("guard_id")
  siteId           String           @map("site_id")
  checkpointId     String           @map("checkpoint_id")
  routeId          String?          @map("route_id")
  scannedAt        DateTime         @map("scanned_at")
  method           AttendanceMethod
  latitude         Float?
  longitude        Float?
  deviceTime       DateTime?        @map("device_time")
  serverReceivedAt DateTime         @default(now()) @map("server_received_at")
  clientEventId    String?          @unique @map("client_event_id")
  syncStatus       SyncStatus       @default(SYNCED) @map("sync_status")
  remarks          String?
  createdAt        DateTime         @default(now()) @map("created_at")

  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id])

  @@index([guardId, scannedAt])
  @@map("patrol_scans")
  @@schema("attendance")
}

model FieldAlert {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  siteId         String   @map("site_id")
  guardId        String?  @map("guard_id")
  alertType      String   @map("alert_type")
  severity       String   @default("MEDIUM")
  message        String
  acknowledged   Boolean  @default(false)
  acknowledgedBy String?  @map("acknowledged_by")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@map("field_alerts")
  @@schema("attendance")
}

// ───────────────────────── OCCURRENCE BOOK ─────────────────────────

model OccurrenceEntry {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  siteId         String   @map("site_id")
  officerId      String   @map("officer_id")
  category       String
  description    String
  version        Int      @default(1)
  isCurrent      Boolean  @default(true) @map("is_current")
  parentEntryId  String?  @map("parent_entry_id")
  correctionReason String? @map("correction_reason")
  approvedBy     String?  @map("approved_by")
  recordedAt     DateTime @map("recorded_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([siteId, recordedAt])
  @@map("occurrence_entries")
  @@schema("occurrence")
}

// ───────────────────────── INCIDENTS ─────────────────────────

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("incidents")
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED

  @@schema("incidents")
}

model Incident {
  id               String           @id @default(uuid())
  organizationId   String           @map("organization_id")
  siteId           String           @map("site_id")
  incidentNumber   String           @map("incident_number")
  category         String
  severity         IncidentSeverity @default(MEDIUM)
  status           IncidentStatus   @default(OPEN)
  title            String
  description      String
  reporterId       String           @map("reporter_id")
  assignedTo       String?          @map("assigned_to")
  latitude         Float?
  longitude        Float?
  clientEventId    String?          @unique @map("client_event_id")
  deviceReportedAt DateTime?        @map("device_reported_at")
  serverReceivedAt DateTime         @default(now()) @map("server_received_at")
  resolvedAt       DateTime?        @map("resolved_at")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@unique([organizationId, incidentNumber])
  @@index([siteId, createdAt])
  @@map("incidents")
  @@schema("incidents")
}

// ───────────────────────── ACCESS (customer employees) ─────────────────────────

enum AccessEntryType {
  CHECK_IN
  CHECK_OUT

  @@schema("access")
}

enum AccessMethod {
  CARD
  QR
  BIOMETRIC
  MANUAL

  @@schema("access")
}

model CustomerEmployee {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  customerId     String   @map("customer_id")
  employeeNumber String?  @map("employee_number")
  fullName       String   @map("full_name")
  email          String?
  phone          String?
  department     String?
  accessCardRef  String?  @map("access_card_ref")
  biometricRef   String?  @map("biometric_ref")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")

  @@index([customerId])
  @@unique([customerId, email])
  @@map("customer_employees")
  @@schema("access")
}

model AccessEntry {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  customerId     String          @map("customer_id")
  employeeId     String          @map("employee_id")
  siteId         String          @map("site_id")
  gateId         String?         @map("gate_id")
  entryType      AccessEntryType @map("entry_type")
  accessMethod   AccessMethod    @default(MANUAL) @map("access_method")
  recordedBy     String?         @map("recorded_by")
  clientEventId  String?         @unique @map("client_event_id")
  recordedAt     DateTime        @default(now()) @map("recorded_at")
