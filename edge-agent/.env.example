# ── PSSMS Edge Agent configuration ──────────────────────────────────────────
# Cloud device-integration API base (core-api). Include the /api/v1 prefix.
EDGE_API_URL=http://localhost:4001/api/v1

# Credentials — set ONE. A site hub forwarding multiple USB devices uses the
# gateway key; a single self-pushing terminal uses the device key.
EDGE_GATEWAY_KEY=
EDGE_DEVICE_KEY=

EDGE_AGENT_VERSION=0.1.0

# Loop timings (ms)
EDGE_POLL_INTERVAL_MS=5000
EDGE_HEARTBEAT_INTERVAL_MS=30000
EDGE_FLUSH_INTERVAL_MS=3000
EDGE_MAX_BATCH=50

# Durable offline event queue (survives restarts)
EDGE_QUEUE_FILE=./data/queue.jsonl

# Log level: error | warn | info | debug
EDGE_LOG_LEVEL=info

# Simulator mode — no hardware; emits synthetic scans and uses a noop printer.
EDGE_SIMULATE=false

# ── USB HID scanner (barcode / QR / RFID / smart-card) ──────────────────────
# The reader MUST be in HID-data / HID-POS mode (not keyboard mode).
EDGE_HID_ENABLED=false
EDGE_HID_VENDOR_ID=0
EDGE_HID_PRODUCT_ID=0
# Optional explicit device path (overrides vendor/product)
EDGE_HID_PATH=
# Device code as registered in the console (must be bound to this gateway)
EDGE_HID_DEVICE_CODE=HID-SCANNER-1
# Event type: BARCODE_SCAN | QR_SCAN | CARD_TAP | FINGERPRINT_SCAN
EDGE_HID_EVENT_TYPE=BARCODE_SCAN

# ── Printer ─────────────────────────────────────────────────────────────────
# Type: escpos (raw TCP 9100) | ipp (port 631) | noop
EDGE_PRINTER_TYPE=noop
EDGE_PRINTER_HOST=127.0.0.1
EDGE_PRINTER_PORT=9100
EDGE_PRINTER_IPP_URL=
EDGE_PRINTER_DEVICE_CODE=PRINTER-1
