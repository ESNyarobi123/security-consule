# HIGHLINK PSSMS — Production env for the lean VPS stack.
# Copy to .env.prod on the server and fill with strong, unique secrets.
# NEVER commit the real .env.prod.

NODE_ENV=production

# ---------- Database ----------
POSTGRES_USER=pssms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=pssms
# Non-owner app role used by core-api so RLS applies (created by seed/migrations)
PSSMS_APP_PASSWORD=CHANGE_ME_strong_app_password

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ---------- Auth / JWT ----------
AUTH_MODE=local
JWT_SECRET=CHANGE_ME_64_char_random_hex
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---------- Integrations ----------
INTEGRATION_SERVICE_TOKEN=CHANGE_ME_random_token
