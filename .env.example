# ============================================================
# HIGHLINK PSSMS — Environment Variables (Development)
# Nakili: cp .env.example .env  (usiweke .env kwenye git)
# ============================================================

NODE_ENV=development

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=pssms
POSTGRES_PASSWORD=pssms_dev_password
POSTGRES_DB=pssms
DATABASE_URL=postgresql://pssms:pssms_dev_password@localhost:5433/pssms

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=pssms_redis_password

# ---------- RabbitMQ (Business Events) ----------
RABBITMQ_USER=pssms
RABBITMQ_PASSWORD=pssms_rabbit_password
RABBITMQ_URL=amqp://pssms:pssms_rabbit_password@localhost:5672

# ---------- MQTT (Device Events) ----------
MQTT_URL=mqtt://localhost:1883
MQTT_WS_URL=ws://localhost:8083/mqtt

# ---------- MinIO (Object Storage) ----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=pssms
MINIO_ROOT_PASSWORD=pssms_minio_password
MINIO_BUCKET_DOCUMENTS=pssms-documents
MINIO_BUCKET_EVIDENCE=pssms-evidence
MINIO_BUCKET_SNAPSHOTS=pssms-cctv-snapshots
MINIO_BUCKET_PAYSLIPS=pssms-payslips

# ---------- Keycloak (IAM) ----------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pssms
KEYCLOAK_ISSUER=http://localhost:8080/realms/pssms
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/pssms/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=pssms-api
# Must match infra/keycloak/pssms-realm.json secret for pssms-api
KEYCLOAK_CLIENT_SECRET=change_me_pssms_api
KEYCLOAK_ADMIN_WEB_CLIENT_ID=pssms-admin-web
# Comma-separated azp allowlist for Keycloak access tokens (defaults: admin-web + api clients)
KEYCLOAK_ALLOWED_AZP=pssms-admin-web,pssms-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password

# ---------- JWT / Sessions ----------
# AUTH_MODE: local (HS256 only) | dual (HS256 + Keycloak RS256, default) | keycloak (RS256 only)
# POST /auth/login always remains for break-glass / E2E; in keycloak mode local JWTs are rejected at the API.
AUTH_MODE=dual
JWT_SECRET=change_me_long_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---------- Backend Service Ports ----------
API_GATEWAY_PORT=4000
CORE_API_PORT=4001
# Phase 16: api-gateway upstream (defaults to CORE_API_INTERNAL_URL / :4001)
CORE_API_URL=http://127.0.0.1:4001
GATEWAY_THROTTLE_TTL=60000
GATEWAY_THROTTLE_LIMIT=120
# Dual mode: portals may stay on :4001; production entry recommended :4000
# NEXT_PUBLIC_CORE_API_URL=http://localhost:4000
BACKGROUND_WORKER_PORT=4002
INTEGRATION_GATEWAY_PORT=4003
REALTIME_GATEWAY_PORT=4004
REPORTING_SERVICE_PORT=4005

# ---------- Python AI Service Ports ----------
VISION_AI_PORT=8000
ANALYTICS_AI_PORT=8001
VISION_AI_URL=http://localhost:8000
ANALYTICS_AI_URL=http://localhost:8001

# ---------- Frontend Ports / URLs ----------
ADMIN_WEB_PORT=3000
EXECUTIVE_WEB_PORT=3001
CUSTOMER_WEB_PORT=3002
SUPPLIER_WEB_PORT=3003
RECRUITMENT_WEB_PORT=3004
VISITOR_WEB_PORT=3005
PARKING_WEB_PORT=3006
PUBLIC_WEB_PORT=3007
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- Integrations (jaza kutoka kwa vendors) ----------
# SMS
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@highlink.co.tz

# Mobile Money (M-Pesa, TigoPesa, Airtel Money, HaloPesa)
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_ENVIRONMENT=sandbox
TIGOPESA_API_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=

# Banks
BANK_API_BASE_URL=
BANK_API_KEY=

# Push Notifications
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# Integration spine (Phase 6)
SMS_PROVIDER=console
PAYMENT_PROVIDER=console
WEBHOOK_VERIFY=false
INTEGRATION_SERVICE_TOKEN=dev_integration_token
CORE_API_INTERNAL_URL=http://localhost:4001
INTEGRATION_GATEWAY_URL=http://localhost:4003
ANALYTICS_AI_URL=http://localhost:8001

# Scheduled KPI refresh (Phase 7b — background-worker)
KPI_REFRESH_ENABLED=true
KPI_REFRESH_UTC_HOUR=21
KPI_REFRESH_UTC_MINUTE=5
# Dev/testing: set e.g. 3600000 for hourly refresh (overrides daily window)
KPI_REFRESH_INTERVAL_MS=0

# Executive web (Phase 7b — local dev)
NEXT_PUBLIC_CORE_API_URL=http://localhost:4001
# Phase 16 dual mode: keep :4001 for local portals; production entry → http://localhost:4000
NEXT_PUBLIC_REPORTING_API_URL=http://localhost:4005
EXECUTIVE_WEB_PORT=3001
REPORTING_SERVICE_PORT=4005
REPORTING_SERVICE_INTERNAL_URL=http://localhost:4005

# ---------- Docker Compose (backend apps) ----------
# When running via ./scripts/docker-up.sh, compose overrides these to service hostnames:
#   postgres:5432, redis, rabbitmq, emqx, core-api, integration-gateway, vision-ai-service
# Host machine still uses localhost:4001, :4003, etc. (ports published)

# ---------- Monitoring ----------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_dev_password
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
